{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memory Guard",
  "version": "0.1.0",
  "identifier": "com.memoryguard.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Memory Guard",
        "label": "main",
        "width": 760,
        "height": 720,
        "minWidth": 520,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://example.com/memory-guard/update/{{target}}/{{current_version}}"
      ]
    }
  }
}
