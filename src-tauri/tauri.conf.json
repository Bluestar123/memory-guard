{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memory Guard",
  "version": "0.1.5",
  "identifier": "com.memoryguard.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Memory Guard",
        "label": "main",
        "width": 760,
        "height": 720,
        "minWidth": 520,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBN0Y4NDJGNkRDMTY1MEIKUldRTFpjRnRMNFIvaWp2a0NCLzhDSzlVVFJldE9hbHA3ZEZsVUhDbnJ6WktVVmRKbHE3V2VnSnEK",
      "endpoints": [
        "https://github.com/Bluestar123/memory-guard/releases/latest/download/latest.json"
      ]
    }
  }
}
